# Credentials and secrets — never commit these
*.key
*.pfx
*.p12
*.cred
secrets.ps1
config.local.ps1

# API keys or tokens accidentally saved
*apikey*
*api_key*
*token*

# Output files generated by scripts
*.csv
*.txt
!README.md
!docs/*.md

# PowerShell session files
*.pses
*.pssc

# VS Code
.vscode/

# Claude Code local session state (allowlist, agent worktrees, etc.)
.claude/

# macOS
.DS_Store

# Windows
Thumbs.db
desktop.ini

# Temp files
*.tmp
*.bak
*.old
